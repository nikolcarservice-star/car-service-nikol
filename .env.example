# Domena (dla canonical, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://carservicenikol.pl

# Google Analytics 4 — Measurement ID (np. G-XXXXXXXXXX)
# Pobierz w: Admin → Data Streams → wybierz strumień → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-8ZGESKN77X

# Google Search Console — weryfikacja meta tag
# W Search Console: Właściwość → Ustawienia → Weryfikacja → meta tag → skopiuj content
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Reviews (Places API)
# Klucz API z Google Cloud (Maps / Places API)
GOOGLE_PLACES_API_KEY=
# ID wizytówki Google (place_id)
GOOGLE_PLACES_PLACE_ID=
